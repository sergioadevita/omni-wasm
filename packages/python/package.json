{
  "name": "@omni-wasm/python",
  "version": "0.1.0",
  "description": "Browser-native Python execution via WebAssembly. CPython 3.12 via Pyodide, no server required.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "build:wasm": "bash build.sh",
    "build:all": "npm run build:wasm && npm run build",
    "test": "node --test tests/",
    "clean": "rm -rf dist"
  },
  "keywords": ["wasm", "webassembly", "python", "cpython", "pyodide", "interpreter", "browser", "no-server"],
  "license": "MIT",
  "author": "Sergio De Vita",
  "dependencies": {
    "@omni-wasm/shared": "*"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sergioadevita/omni-wasm.git",
    "directory": "packages/python"
  },
  "engines": { "node": ">=20.0.0" }
}
